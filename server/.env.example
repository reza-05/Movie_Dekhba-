# Server port (defaults to 5001)
PORT=5001

# Cloudflare R2 Credentials (for bufferless CDN streaming)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=your_r2_bucket-name
CLOUDFLARE_R2_PUBLIC_URL=https://pub-yourbucket.r2.dev
